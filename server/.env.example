## Runtime DB URL used by Prisma Client inside the app.
## For Supabase in production, prefer a pooler/session URL that your host can reach.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/level_test_app?schema=public&sslmode=require"

## Direct DB URL used by Prisma for migrations/introspection (directUrl in schema.prisma).
## For Supabase this is typically the direct db.<project-ref>.supabase.co:5432 endpoint.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/level_test_app?schema=public&sslmode=require"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000
UPLOAD_DIR="./uploads"

# Optional: when the client uses VITE_API_URL (absolute API URL), list browser origins here (comma-separated).
# CORS_ORIGINS=http://192.168.1.103:5173
# FRONTEND_ORIGIN=http://192.168.1.103:5173
